#: includes/class-blocks.php:68
msgid "Resend confirmation email"
msgstr "확인 이메일 재발송"

#: includes/class-blocks.php:167
msgid "Forum Feed"
msgstr "포럼 피드"

#: includes/class-blocks.php:168
msgid ""
"Display recent forum discussions. Optionally scope to a single space with a "
"header."
msgstr "최근 포럼 토론을 표시해요. 선택적으로 헤더와 함께 단일 스페이스로 범위를 지정할 수 있어요."

#: includes/class-blocks.php:204
msgid "Trending Topics"
msgstr "인기 주제"

#: includes/class-blocks.php:205
msgid ""
