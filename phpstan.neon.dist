includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon
    - phpstan-baseline.neon

parameters:
    level: 5
    paths:
        - includes/
    scanFiles:
        - jetonomy.php
    scanDirectories:
        - /tmp/bp-stubs/buddypress
    ignoreErrors:
        # Third-party plugin classes not available in CI
        -
            message: '#(Mepr|MeprUser|MeprCptModel)#'
            reportUnmatched: false
        # WP-CLI stubs aren't installed in CI. The CLI module (commands +
        # dispatcher) uses WP_CLI::log/success/error/warning and the
        # WP_CLI\Utils helpers; they only run inside `wp` where the class
        # is always defined.
        -
            message: '#Call to static method (log|success|error|warning|add_command)\(\) on an unknown class WP_CLI\.#'
            paths:
                - includes/cli/*
            reportUnmatched: false
        -
            message: '#Function WP_CLI\\Utils\\\w+ not found\.#'
            paths:
                - includes/cli/*
            reportUnmatched: false
