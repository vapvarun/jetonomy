includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon
    - phpstan-baseline.neon

parameters:
    level: 5
    bootstrapFiles:
        - phpstan-bootstrap.php
    paths:
        - includes/
    scanFiles:
        - jetonomy.php
        - libs/action-scheduler/functions.php
    scanDirectories:
        - /tmp/bp-stubs/buddypress
    ignoreErrors:
        # Third-party plugin classes not available in CI
        -
            message: '#(Mepr|MeprUser|MeprCptModel)#'
            reportUnmatched: false
        # WP-CLI stubs aren't installed in CI. The CLI module (commands +
        # dispatcher) and the qa-actions journey harness use
        # WP_CLI::log/success/error/warning and the WP_CLI\Utils helpers;
        # they only run inside `wp` where the class is always defined.
        -
            message: '#Call to static method (log|success|error|warning|add_command|line|colorize|halt|confirm|read_value)\(\) on an unknown class WP_CLI\.#'
            paths:
                - includes/cli/*
                - includes/class-cli.php
                - includes/qa/*
            reportUnmatched: false
        -
            message: '#Function WP_CLI\\Utils\\\w+ not found\.#'
            paths:
                - includes/cli/*
                - includes/class-cli.php
                - includes/qa/*
            reportUnmatched: false
