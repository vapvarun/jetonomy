{
  "$schema": "https://wpmediaverse.com/schemas/wp-plugin-manifest-v1.json",
  "plugin": {
    "slug": "jetonomy",
    "name": "Jetonomy",
    "version": "1.4.0",
    "namespace": "Jetonomy",
    "main_file": "jetonomy.php",
    "text_domain": "jetonomy",
    "extends": null,
    "extension_hook_consumed": null,
    "extension_hook_fired": "jetonomy_extensions_init"
  },
  "rest": {
    "namespace": "jetonomy/v1",
    "endpoints": [
      {"route": "/spaces/(?P<space_id>\\d+)/posts", "methods": ["GET", "POST"], "handler": "Posts_Controller::list_items,create_item", "permission": "__return_true,login_permission_check", "purpose": "List posts in a space or create new post"},
      {"route": "/posts/drafts", "methods": ["GET"], "handler": "Posts_Controller::list_drafts", "permission": "__return_true", "purpose": "List draft posts for current user"},
      {"route": "/posts/(?P<id>\\d+)", "methods": ["GET", "PATCH", "DELETE"], "handler": "Posts_Controller::get_item,update_item,delete_item", "permission": "__return_true,login_permission_check", "purpose": "Get, update, or delete a single post"},
      {"route": "/posts/(?P<id>\\d+)/close", "methods": ["POST"], "handler": "Posts_Controller::close_post", "permission": "login_permission_check", "purpose": "Close/lock a post"},
      {"route": "/posts/(?P<id>\\d+)/pin", "methods": ["POST"], "handler": "Posts_Controller::pin_post", "permission": "login_permission_check", "purpose": "Pin a post to top of space"},
      {"route": "/posts/(?P<id>\\d+)/move", "methods": ["POST"], "handler": "Posts_Controller::move_post", "permission": "login_permission_check", "purpose": "Move post to another space"},
      {"route": "/posts/(?P<id>\\d+)/merge", "methods": ["POST"], "handler": "Posts_Controller::merge_post", "permission": "login_permission_check", "purpose": "Merge post with another post"},
      {"route": "/link-preview", "methods": ["GET"], "handler": "Posts_Controller::link_preview", "permission": "__return_true", "purpose": "Fetch OG metadata for link preview cards"},
      {"route": "/spaces", "methods": ["GET", "POST"], "handler": "Spaces_Controller::list_items,create_item", "permission": "__return_true,login_permission_check", "purpose": "List all spaces or create new space"},
      {"route": "/spaces/(?P<id>\\d+)", "methods": ["GET", "PATCH", "DELETE"], "handler": "Spaces_Controller::get_item,update_item,delete_item", "permission": "__return_true", "purpose": "Get, update, or delete a space"},
      {"route": "/spaces/(?P<id>\\d+)/members", "methods": ["GET", "POST"], "handler": "Spaces_Controller::list_members,add_member", "permission": "__return_true", "purpose": "List space members or add new member"},
      {"route": "/spaces/(?P<id>\\d+)/members/(?P<member_id>\\d+)", "methods": ["PATCH", "DELETE"], "handler": "Spaces_Controller::update_member,remove_member", "permission": "login_permission_check", "purpose": "Update or remove space member"},
      {"route": "/spaces/(?P<id>\\d+)/join", "methods": ["POST"], "handler": "Spaces_Controller::join_space", "permission": "login_permission_check", "purpose": "Request to join a space"},
      {"route": "/spaces/(?P<id>\\d+)/leave", "methods": ["POST"], "handler": "Spaces_Controller::leave_space", "permission": "login_permission_check", "purpose": "Leave a space"},
      {"route": "/spaces/(?P<id>\\d+)/join-requests", "methods": ["GET"], "handler": "Spaces_Controller::list_join_requests", "permission": "login_permission_check", "purpose": "List pending join requests for space"},
      {"route": "/replies", "methods": ["POST"], "handler": "Replies_Controller::create_item", "permission": "login_permission_check", "purpose": "Create a new reply"},
      {"route": "/replies/(?P<id>\\d+)", "methods": ["GET", "PATCH", "DELETE"], "handler": "Replies_Controller::get_item,update_item,delete_item", "permission": "__return_true", "purpose": "Get, update, or delete a reply"},
      {"route": "/replies/(?P<id>\\d+)/accept-answer", "methods": ["POST"], "handler": "Replies_Controller::accept_answer", "permission": "login_permission_check", "purpose": "Mark reply as accepted answer"},
      {"route": "/votes", "methods": ["POST"], "handler": "Votes_Controller::create_item", "permission": "login_permission_check", "purpose": "Create/toggle a vote"},
      {"route": "/votes/(?P<id>\\d+)", "methods": ["DELETE"], "handler": "Votes_Controller::delete_item", "permission": "login_permission_check", "purpose": "Remove a vote"},
      {"route": "/users/(?P<id>\\d+)", "methods": ["GET", "PATCH"], "handler": "Users_Controller::get_item,update_item", "permission": "__return_true", "purpose": "Get or update user profile"},
      {"route": "/users/(?P<id>\\d+)/ban", "methods": ["POST"], "handler": "Users_Controller::ban_user", "permission": "login_permission_check", "purpose": "Ban a user from community"},
      {"route": "/users/(?P<id>\\d+)/unban", "methods": ["POST"], "handler": "Users_Controller::unban_user", "permission": "login_permission_check", "purpose": "Unban a user"},
      {"route": "/users/search", "methods": ["GET"], "handler": "Users_Controller::search_users", "permission": "login_permission_check", "purpose": "Search users by name or login"},
      {"route": "/notifications", "methods": ["GET"], "handler": "Notifications_Controller::list_items", "permission": "login_permission_check", "purpose": "List notifications for current user"},
      {"route": "/notifications/(?P<id>\\d+)/read", "methods": ["POST"], "handler": "Notifications_Controller::mark_read", "permission": "login_permission_check", "purpose": "Mark notification as read"},
      {"route": "/notifications/read-all", "methods": ["POST"], "handler": "Notifications_Controller::mark_all_read", "permission": "login_permission_check", "purpose": "Mark all notifications as read"},
      {"route": "/subscriptions", "methods": ["POST"], "handler": "Subscriptions_Controller::create_item", "permission": "login_permission_check", "purpose": "Subscribe to a space or post"},
      {"route": "/subscriptions/(?P<id>\\d+)", "methods": ["DELETE"], "handler": "Subscriptions_Controller::delete_item", "permission": "login_permission_check", "purpose": "Unsubscribe from space or post"},
      {"route": "/search", "methods": ["GET"], "handler": "Search_Controller::search", "permission": "__return_true", "purpose": "Full-text search posts and replies"},
      {"route": "/moderation/queue", "methods": ["GET"], "handler": "Moderation_Controller::list_queue", "permission": "login_permission_check", "purpose": "List flagged content in moderation queue"},
      {"route": "/moderation/(?P<id>\\d+)/approve", "methods": ["POST"], "handler": "Moderation_Controller::approve_item", "permission": "login_permission_check", "purpose": "Approve flagged content"},
      {"route": "/moderation/(?P<id>\\d+)/spam", "methods": ["POST"], "handler": "Moderation_Controller::spam_item", "permission": "login_permission_check", "purpose": "Mark content as spam"},
      {"route": "/moderation/(?P<id>\\d+)/trash", "methods": ["POST"], "handler": "Moderation_Controller::trash_item", "permission": "login_permission_check", "purpose": "Move content to trash"},
      {"route": "/categories", "methods": ["GET", "POST"], "handler": "Categories_Controller::list_items,create_item", "permission": "__return_true", "purpose": "List all categories or create new"},
      {"route": "/categories/(?P<id>\\d+)", "methods": ["GET", "PATCH", "DELETE"], "handler": "Categories_Controller::get_item,update_item,delete_item", "permission": "__return_true", "purpose": "Get, update, or delete category"},
      {"route": "/tags", "methods": ["GET", "POST"], "handler": "Tags_Controller::list_items,create_item", "permission": "__return_true", "purpose": "List all tags or create new"},
      {"route": "/tags/(?P<id>\\d+)", "methods": ["GET", "PATCH", "DELETE"], "handler": "Tags_Controller::get_item,update_item,delete_item", "permission": "__return_true", "purpose": "Get, update, or delete tag"},
      {"route": "/updates", "methods": ["GET"], "handler": "Updates_Controller::get_updates", "permission": "__return_true", "purpose": "Get plugin update information"},
      {"route": "/leaderboards", "methods": ["GET"], "handler": "Leaderboards_Controller::get_leaderboard", "permission": "__return_true", "purpose": "Get community leaderboard data"},
      {"route": "/bookmarks", "methods": ["GET", "POST"], "handler": "Bookmarks_Controller::list_items,create_item", "permission": "login_permission_check", "purpose": "List or create user bookmarks"},
      {"route": "/bookmarks/(?P<id>\\d+)", "methods": ["DELETE"], "handler": "Bookmarks_Controller::delete_item", "permission": "login_permission_check", "purpose": "Remove bookmark"},
      {"route": "/oembed", "methods": ["GET"], "handler": "OEmbed_Controller::get_oembed", "permission": "__return_true", "purpose": "oEmbed endpoint for Jetonomy posts"},
      {"route": "/media/upload", "methods": ["POST"], "handler": "Media_Controller::upload_media", "permission": "login_permission_check", "purpose": "Upload media (image, video, file)"},
      {"route": "/auth/login", "methods": ["POST"], "handler": "Auth_Controller::login", "permission": "__return_true", "purpose": "Login via REST API"},
      {"route": "/auth/register", "methods": ["POST"], "handler": "Auth_Controller::register", "permission": "__return_true", "purpose": "Register new user account"},
      {"route": "/auth/logout", "methods": ["POST"], "handler": "Auth_Controller::logout", "permission": "login_permission_check", "purpose": "Logout current user"},
      {"route": "/auth/verify-email", "methods": ["POST"], "handler": "Auth_Controller::verify_email", "permission": "__return_true", "purpose": "Verify email confirmation token"},
      {"route": "/admin/settings", "methods": ["GET", "POST"], "handler": "Admin_Controller::get_settings,update_settings", "permission": "login_permission_check", "purpose": "Get or update plugin settings (admin only)"},
      {"route": "/space-moderation/queue", "methods": ["GET"], "handler": "Space_Moderation_Controller::list_queue", "permission": "login_permission_check", "purpose": "List moderation queue for space"},
      {"route": "/space-moderation/(?P<id>\\d+)/approve", "methods": ["POST"], "handler": "Space_Moderation_Controller::approve", "permission": "login_permission_check", "purpose": "Approve flagged content in space"},
      {"route": "/space-moderation/(?P<id>\\d+)/spam", "methods": ["POST"], "handler": "Space_Moderation_Controller::spam", "permission": "login_permission_check", "purpose": "Mark as spam in space"}
    ]
  },
  "ajax": [
    {"action": "jetonomy_categories_create", "handler": "Admin\\Ajax\\Categories_Handler::create", "nonce": "jetonomy_nonce", "capability": "jetonomy_manage_categories", "purpose": "Create category"},
    {"action": "jetonomy_categories_update", "handler": "Admin\\Ajax\\Categories_Handler::update", "nonce": "jetonomy_nonce", "capability": "jetonomy_manage_categories", "purpose": "Update category"},
    {"action": "jetonomy_spaces_create", "handler": "Admin\\Ajax\\Spaces_Handler::create", "nonce": "jetonomy_nonce", "capability": "jetonomy_manage_spaces", "purpose": "Create space"},
    {"action": "jetonomy_moderation_approve", "handler": "Admin\\Ajax\\Moderation_Handler::approve", "nonce": "jetonomy_nonce", "capability": "jetonomy_moderate", "purpose": "Approve flagged content"},
    {"action": "jetonomy_moderation_spam", "handler": "Admin\\Ajax\\Moderation_Handler::spam", "nonce": "jetonomy_nonce", "capability": "jetonomy_moderate", "purpose": "Mark as spam"},
    {"action": "jetonomy_settings_test_email", "handler": "Admin\\Ajax\\Settings_Handler::test_email", "nonce": "jetonomy_nonce", "capability": "jetonomy_manage_settings", "purpose": "Test email"},
    {"action": "jetonomy_import_run", "handler": "Admin\\Ajax\\Import_Handler::run", "nonce": "jetonomy_nonce", "capability": "jetonomy_manage_settings", "purpose": "Run import"}
  ],
  "admin_pages": [
    {"title": "Jetonomy", "slug": "jetonomy", "parent": null, "capability": "jetonomy_manage_settings", "source": "includes/admin/class-admin.php"},
    {"title": "Dashboard", "slug": "jetonomy", "parent": "jetonomy", "capability": "jetonomy_manage_settings", "source": "includes/admin/class-admin.php"},
    {"title": "Categories", "slug": "jetonomy-categories", "parent": "jetonomy", "capability": "jetonomy_manage_settings", "source": "includes/admin/class-admin.php"},
    {"title": "Tags", "slug": "jetonomy-tags", "parent": "jetonomy", "capability": "jetonomy_manage_settings", "source": "includes/admin/class-admin.php"},
    {"title": "Spaces", "slug": "jetonomy-spaces", "parent": "jetonomy", "capability": "jetonomy_manage_settings", "source": "includes/admin/class-admin.php"},
    {"title": "Content", "slug": "jetonomy-content", "parent": "jetonomy", "capability": "jetonomy_manage_settings", "source": "includes/admin/class-admin.php"},
    {"title": "Moderation", "slug": "jetonomy-moderation", "parent": "jetonomy", "capability": "jetonomy_moderate", "source": "includes/admin/class-admin.php"},
    {"title": "Users", "slug": "jetonomy-users", "parent": "jetonomy", "capability": "jetonomy_manage_settings", "source": "includes/admin/class-admin.php"},
    {"title": "Import", "slug": "jetonomy-import", "parent": "jetonomy", "capability": "jetonomy_manage_settings", "source": "includes/admin/class-admin.php"},
    {"title": "Settings", "slug": "jetonomy-settings", "parent": "jetonomy", "capability": "jetonomy_manage_settings", "source": "includes/admin/class-admin.php"},
    {"title": "Setup", "slug": "jetonomy-setup", "parent": null, "capability": "manage_options", "source": "includes/admin/class-admin.php"}
  ],
  "settings": [
    {"key": "jetonomy_settings", "group": "jetonomy_settings", "type": "array", "default": {}, "controls": "base_slug, default_space_type, notification_defaults, trust_thresholds, rate_limits, activity_log_retention_days"},
    {"key": "jetonomy_email_templates", "group": "jetonomy_settings", "type": "array", "default": {}, "controls": "user_welcome, reply_to_post, reply_to_reply, mention, accepted_answer, new_post_in_sub, badge_earned, vote_on_post, moderation, join_request"}
  ],
  "shortcodes": [
    {"tag": "jetonomy_recent_posts", "handler": "Shortcodes::recent_posts", "attrs": ["count", "space_id", "sort"]},
    {"tag": "jetonomy_trending_posts", "handler": "Shortcodes::trending_posts", "attrs": ["count", "space_id"]},
    {"tag": "jetonomy_spaces", "handler": "Shortcodes::spaces", "attrs": ["count", "category_id"]},
    {"tag": "jetonomy_leaderboard", "handler": "Shortcodes::leaderboard", "attrs": ["limit"]},
    {"tag": "jetonomy_user_profile", "handler": "Shortcodes::user_profile", "attrs": ["user_id"]},
    {"tag": "jetonomy_space_members", "handler": "Shortcodes::space_members", "attrs": ["space_id", "limit"]},
    {"tag": "jetonomy_compose_topic", "handler": "Shortcodes::compose_topic", "attrs": ["space_id"]},
    {"tag": "jetonomy_widget", "handler": "Shortcodes::widget_embed", "attrs": ["widget_id"]}
  ],
  "blocks": [
    {"name": "jetonomy/forum-feed", "render": "Shortcodes::recent_posts", "interactivity": false, "purpose": "Display recent posts"},
    {"name": "jetonomy/trending-posts", "render": "Shortcodes::trending_posts", "interactivity": false, "purpose": "Display trending posts"},
    {"name": "jetonomy/spaces", "render": "Shortcodes::spaces", "interactivity": false, "purpose": "Display spaces"},
    {"name": "jetonomy/leaderboard", "render": "Shortcodes::leaderboard", "interactivity": false, "purpose": "Display leaderboard"},
    {"name": "jetonomy/compose-topic", "render": "Blocks::render_compose_topic", "interactivity": true, "purpose": "Composer with Interactivity API"},
    {"name": "jetonomy/navigation", "render": "Blocks::render_navigation", "interactivity": false, "purpose": "Navigation menu"},
    {"name": "jetonomy/login", "render": "Blocks::render_login", "interactivity": false, "purpose": "Login form"},
    {"name": "jetonomy/user-panel", "render": "Blocks::render_user_panel", "interactivity": false, "purpose": "User panel"}
  ],
  "post_types": [],
  "taxonomies": [],
  "tables": [
    {"name": "{prefix}jt_categories", "purpose": "Categories/sections"},
    {"name": "{prefix}jt_spaces", "purpose": "Forums, Q&A, ideas, feeds"},
    {"name": "{prefix}jt_posts", "purpose": "Posts and questions"},
    {"name": "{prefix}jt_replies", "purpose": "Replies and answers"},
    {"name": "{prefix}jt_votes", "purpose": "Up/down votes"},
    {"name": "{prefix}jt_user_profiles", "purpose": "User profile data"},
    {"name": "{prefix}jt_notifications", "purpose": "User notifications"},
    {"name": "{prefix}jt_subscriptions", "purpose": "Subscriptions"},
    {"name": "{prefix}jt_read_status", "purpose": "Read status tracking"},
    {"name": "{prefix}jt_space_members", "purpose": "Space membership"},
    {"name": "{prefix}jt_tags", "purpose": "Topic tags"},
    {"name": "{prefix}jt_post_tags", "purpose": "Post tags"},
    {"name": "{prefix}jt_space_tags", "purpose": "Space tags"},
    {"name": "{prefix}jt_space_tag_map", "purpose": "Space tag mapping"},
    {"name": "{prefix}jt_user_interests", "purpose": "User interests"},
    {"name": "{prefix}jt_activity_log", "purpose": "Activity audit"},
    {"name": "{prefix}jt_restrictions", "purpose": "User bans"},
    {"name": "{prefix}jt_access_rules", "purpose": "Access control"},
    {"name": "{prefix}jt_flags", "purpose": "Flagged content"},
    {"name": "{prefix}jt_revisions", "purpose": "Edit history"},
    {"name": "{prefix}jt_join_requests", "purpose": "Join requests"},
    {"name": "{prefix}jt_invite_links", "purpose": "Invite links"},
    {"name": "{prefix}jt_bookmarks", "purpose": "User bookmarks"}
  ],
  "capabilities": [
    {"cap": "jetonomy_read", "default_roles": ["subscriber", "contributor", "author", "editor", "administrator"]},
    {"cap": "jetonomy_create_posts", "default_roles": ["contributor", "author", "editor", "administrator"]},
    {"cap": "jetonomy_create_replies", "default_roles": ["contributor", "author", "editor", "administrator"]},
    {"cap": "jetonomy_edit_own_posts", "default_roles": ["contributor", "author", "editor", "administrator"]},
    {"cap": "jetonomy_delete_own_posts", "default_roles": ["contributor", "author", "editor", "administrator"]},
    {"cap": "jetonomy_vote", "default_roles": ["subscriber", "contributor", "author", "editor", "administrator"]},
    {"cap": "jetonomy_flag", "default_roles": ["subscriber", "contributor", "author", "editor", "administrator"]},
    {"cap": "jetonomy_join_spaces", "default_roles": ["subscriber", "contributor", "author", "editor", "administrator"]},
    {"cap": "jetonomy_upload_media", "default_roles": ["author", "editor", "administrator"]},
    {"cap": "jetonomy_create_spaces", "default_roles": ["editor", "administrator"]},
    {"cap": "jetonomy_edit_others_posts", "default_roles": ["editor", "administrator"]},
    {"cap": "jetonomy_delete_others_posts", "default_roles": ["administrator"]},
    {"cap": "jetonomy_moderate", "default_roles": ["editor", "administrator"]},
    {"cap": "jetonomy_manage_users", "default_roles": ["administrator"]},
    {"cap": "jetonomy_move_posts", "default_roles": ["editor", "administrator"]},
    {"cap": "jetonomy_close_posts", "default_roles": ["editor", "administrator"]},
    {"cap": "jetonomy_pin_posts", "default_roles": ["editor", "administrator"]},
    {"cap": "jetonomy_manage_settings", "default_roles": ["administrator"]},
    {"cap": "jetonomy_manage_categories", "default_roles": ["administrator"]},
    {"cap": "jetonomy_manage_spaces", "default_roles": ["administrator"]},
    {"cap": "jetonomy_manage_badges", "default_roles": ["administrator"]},
    {"cap": "jetonomy_view_analytics", "default_roles": ["administrator"]},
    {"cap": "jetonomy_manage_extensions", "default_roles": ["administrator"]}
  ],
  "services": [],
  "hooks_fired": [
    {"name": "jetonomy_extensions_init", "type": "action", "args": "none", "where": "includes/class-jetonomy.php", "consumed_by": "jetonomy-pro"},
    {"name": "jetonomy_trust_evaluation", "type": "action", "args": "cron-only", "where": "includes/class-cron.php", "consumed_by": null},
    {"name": "jetonomy_trust_level_changed", "type": "action", "args": "user_id, old_level, new_level", "where": "includes/class-cron.php", "consumed_by": null},
    {"name": "jetonomy_new_post_submit_action", "type": "filter", "args": "url", "where": "includes/blocks/", "consumed_by": null}
  ],
  "buddypress_integration": {
    "enabled_when": "function_exists('buddypress')",
    "manager": "Jetonomy\\Integrations\\BuddyPress",
    "sub_classes": []
  },
  "frontend_assets": {
    "js": [
      {"handle": "jetonomy-view", "path": "assets/js/view.js", "deps": ["@wordpress/interactivity"]},
      {"handle": "jetonomy-login-block", "path": "assets/js/login-block.js", "deps": []},
      {"handle": "jetonomy-compose-topic-block", "path": "assets/js/compose-topic-block.js", "deps": ["wp-blocks", "wp-element"]},
      {"handle": "jetonomy-blocks-editor", "path": "assets/js/blocks-editor.js", "deps": ["wp-blocks", "wp-element"]},
      {"handle": "jetonomy-modals", "path": "assets/js/jetonomy-modals.js", "deps": []},
      {"handle": "jetonomy-composer", "path": "assets/js/composer.js", "deps": []},
      {"handle": "jetonomy-moderation", "path": "assets/js/moderation.js", "deps": []},
      {"handle": "jetonomy-space-members", "path": "assets/js/space-members.js", "deps": []},
      {"handle": "jetonomy-admin", "path": "assets/js/admin.js", "deps": ["jquery"]}
    ],
    "css": [
      {"handle": "jetonomy", "path": "assets/css/jetonomy.css", "deps": []},
      {"handle": "jetonomy-blocks", "path": "assets/css/blocks.css", "deps": []},
      {"handle": "jetonomy-blocks-editor", "path": "assets/css/blocks-editor.css", "deps": []},
      {"handle": "jetonomy-admin", "path": "assets/css/admin.css", "deps": []},
      {"handle": "jetonomy-fluent-community", "path": "assets/css/fluent-community.css", "deps": []}
    ]
  },
  "cron": [
    {"hook": "jetonomy_trust_evaluation", "schedule": "twicedaily", "purpose": "Evaluate trust levels"},
    {"hook": "jetonomy_cleanup_expired", "schedule": "hourly", "purpose": "Clean expired restrictions"},
    {"hook": "jetonomy_prune_activity", "schedule": "daily", "purpose": "Prune activity log"},
    {"hook": "jetonomy_cleanup_notifications", "schedule": "weekly", "purpose": "Clean old notifications"},
    {"hook": "jetonomy_publish_scheduled", "schedule": "hourly", "purpose": "Publish scheduled posts"}
