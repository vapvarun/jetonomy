  "wp_cli": [
    {"command": "jetonomy category", "handler": "CLI\\Commands\\Category_Command", "subcommands": ["create", "list", "update", "delete"]},
    {"command": "jetonomy space", "handler": "CLI\\Commands\\Space_Command", "subcommands": ["create", "list", "update", "delete"]},
    {"command": "jetonomy post", "handler": "CLI\\Commands\\Post_Command", "subcommands": ["create", "list", "update", "delete"]},
    {"command": "jetonomy reply", "handler": "CLI\\Commands\\Reply_Command", "subcommands": ["create", "list"]},
    {"command": "jetonomy user", "handler": "CLI\\Commands\\User_Command", "subcommands": ["ban", "unban", "promote"]},
    {"command": "jetonomy scenario", "handler": "CLI\\Commands\\Scenario_Command", "subcommands": ["run", "list"]},
    {"command": "jetonomy qa-actions", "handler": "CLI\\Commands\\Base_Command", "subcommands": ["run"]}
  ],
  "storage_drivers": [],
  "security": {
    "uploads_gate": "includes/api/class-media-controller.php",
    "signing_entry_points": [],
    "always_sign_filter": null,
    "rate_limit_middleware": "includes/permissions/class-rate-limiter.php"
  },
  "ci_guards": {
    "script": "bin/build-release.sh",
    "url_emission_regex": null,
    "storage_internal_marker": null,
    "phpstan_level": 5,
    "phpstan_baseline": "phpstan-baseline.neon",
    "phpcs_config": "phpcs.xml"
  },
  "coding_rules": [
    "REST-first: every mutation reachable via jetonomy/v1/*",
    "Frontend REST-only; admin AJAX acceptable",
    "RTL-ready with logical CSS properties",
    "readme.txt is customer-facing copy",
    "AJAX handlers live in includes/admin/ajax/",
    "Settings are merged, never replaced",
    "Use --jt-* CSS tokens for theming",
    "Every release zip must come from bin/build-release.sh"
  ],
  "build_commands": {
    "release": "bin/build-release.sh",
    "ci_local": "composer test"
  },
